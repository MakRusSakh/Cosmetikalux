# CosmetikaLux Environment Variables
# Copy to .env and fill in values

# PostgreSQL (Neon recommended for Vercel)
DATABASE_URL="postgresql://user:password@host:5432/cosmetikalux?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# SMS.ru
SMS_RU_API_KEY=""

# Resend (email)
RESEND_API_KEY=""

# Site
NEXT_PUBLIC_BASE_URL="https://cosmetikalux.ru"
